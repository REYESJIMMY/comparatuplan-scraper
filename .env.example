# ══════════════════════════════════════════════════════
# .env — ComparaTuPlan Scraper
# Copiar como .env y rellenar con valores reales
# ══════════════════════════════════════════════════════

# URL base de Supabase (el scraper extrae la base automáticamente)
SUPABASE_WEBHOOK_URL=https://TU_PROYECTO.supabase.co/functions/v1/webhook-receiver

# Claves de Supabase (Settings → API)
SUPABASE_ANON_KEY=eyJ...tu_anon_key
SUPABASE_SERVICE_KEY=eyJ...tu_service_key

# Secret para la Edge Function (si la usas)
WEBHOOK_SECRET=tu_webhook_secret_aqui
